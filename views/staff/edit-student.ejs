<%- include('../layout/header') %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Error Messages -->
            <% if (error_msg && error_msg.length > 0) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong><i class="fas fa-exclamation-circle"></i> Error:</strong>
                    <% error_msg.forEach(msg => { %>
                        <p class="mb-0"><%= msg %></p>
                    <% }); %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <!-- Success Messages -->
            <% if (success_msg && success_msg.length > 0) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <strong><i class="fas fa-check-circle"></i> Success:</strong>
                    <% success_msg.forEach(msg => { %>
                        <p class="mb-0"><%= msg %></p>
                    <% }); %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <div class="card shadow-lg border-0" style="border-radius: 2rem; overflow: hidden;">
                <div class="card-header bg-success text-white p-4 text-center">
                    <h3 class="mb-1 fw-bold"><i class="fas fa-user-edit me-3"></i>Edit Student Profile</h3>
                    <p class="mb-0 opacity-75">Updating record for <%= student.first_name %> <%= student.last_name %> (#<%= student.admission_number %>)</p>
                </div>
                <div class="card-body p-5">
                    <form action="/staff/edit-student/<%= student.id %>" method="POST" enctype="multipart/form-data" id="editStudentForm">

                        <div class="row g-4">
                            <!-- Personal Info -->
                            <div class="col-12">
                                <h5 class="text-success fw-bold border-bottom pb-2 mb-4">Personal Information</h5>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">First Name</label>
                                <input type="text" name="first_name" class="form-control" value="<%= student.first_name %>" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Last Name</label>
                                <input type="text" name="last_name" class="form-control" value="<%= student.last_name %>" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Gender</label>
                                <select name="gender" class="form-select">
                                    <option value="male" <%= student.gender === 'male' ? 'selected' : '' %>>Male</option>
                                    <option value="female" <%= student.gender === 'female' ? 'selected' : '' %>>Female</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Date of Birth</label>
                                <input type="date" name="date_of_birth" class="form-control" value="<%= student.date_of_birth ? new Date(student.date_of_birth).toISOString().split('T')[0] : '' %>">
                            </div>

                            <div class="col-md-12">
                                <label class="form-label small fw-bold text-muted text-uppercase">Passport Number</label>
                                <input type="text" name="passport" class="form-control" value="<%= student.passport || '' %>" placeholder="Enter passport number">
                            </div>

                            <div class="col-md-12">
                                <label class="form-label small fw-bold text-muted text-uppercase">Profile Picture</label>
                                <input type="file" name="profile_picture" class="form-control" accept="image/*">
                                <div class="form-text">Upload a new profile picture (JPG, PNG, max 2MB)</div>
                                <% if (student.picture) { %>
                                <div class="mt-2">
                                    <small class="text-muted">Current picture:</small><br>
                                    <img src="<%= student.picture %>" alt="Current picture" style="max-width: 100px; max-height: 100px; border-radius: 8px; border: 1px solid #ddd;">
                                </div>
                                <% } %>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label small fw-bold text-muted text-uppercase">Current Class</label>
                                <select name="class_name" class="form-select" required>
                                    <% ['PRELIMINARY 2', 'PRELIMINARY 3', 'ALIF CLASS', 'BA CLASS', 'TA CLASS'].forEach(cls => { %>
                                    <option value="<%= cls %>" <%= student.class === cls ? 'selected' : '' %>><%= cls %></option>
                                    <% }); %>
                                </select>
                            </div>

                            <!-- Parental Info -->
                            <div class="col-12 mt-5">
                                <h5 class="text-success fw-bold border-bottom pb-2 mb-4">Parent/Guardian Information</h5>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Parent Name</label>
                                <input type="text" name="parent_name" class="form-control" value="<%= student.parent_name %>" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">Parent Phone</label>
                                <input type="tel" name="parent_phone" class="form-control" value="<%= student.parent_phone %>" required>
                            </div>

                            <div class="col-12">
                                <label class="form-label small fw-bold text-muted text-uppercase">Parent Email</label>
                                <input type="email" name="parent_email" class="form-control" value="<%= student.parent_email %>">
                            </div>

                            <div class="col-12">
                                <label class="form-label small fw-bold text-muted text-uppercase">Residential Address</label>
                                <textarea name="address" class="form-control" rows="3"><%= student.address %></textarea>
                            </div>

                            <div class="col-12 mt-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex gap-2">
                                        <a href="/staff/manage-students" class="btn btn-light px-4 py-2 fw-bold">
                                            <i class="fas fa-times me-2"></i>Cancel
                                        </a>
                                        <button type="button" class="btn btn-outline-danger px-4 py-2 fw-bold" id="deleteBtn" data-id="<%= student.id %>" data-name="<%= student.first_name %> <%= student.last_name %>">
                                            <i class="fas fa-trash-alt me-2"></i>Delete Student
                                        </button>
                                    </div>
                                    <button type="submit" class="btn btn-success px-5 py-2 fw-bold shadow">
                                        <i class="fas fa-save me-2"></i>Save Changes
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Simple form validation without preventing default
    document.getElementById('editStudentForm').addEventListener('submit', function(e) {
        const firstName = document.querySelector('input[name="first_name"]').value.trim();
        const lastName = document.querySelector('input[name="last_name"]').value.trim();
        const className = document.querySelector('select[name="class_name"]').value;
        const parentName = document.querySelector('input[name="parent_name"]').value.trim();
        const parentPhone = document.querySelector('input[name="parent_phone"]').value.trim();

        // Validate required fields
        if (!firstName || !lastName || !className || !parentName || !parentPhone) {
            e.preventDefault();
            alert('⚠️ Please fill in all required fields:\n- First Name\n- Last Name\n- Class\n- Parent Name\n- Parent Phone');
            return false;
        }

        console.log('✅ Form validation passed, submitting...');
        // Form will submit normally
    });

    // Handle delete button
    document.getElementById('deleteBtn').addEventListener('click', function() {
        const id = this.getAttribute('data-id');
        const name = this.getAttribute('data-name');

        if (confirm(`⚠️ PERMANENT ACTION: Are you sure you want to delete ${name}?\n\nThis will permanently delete their account, results, and all history. This cannot be undone.`)) {
            const deleteForm = document.createElement('form');
            deleteForm.method = 'POST';
            deleteForm.action = `/staff/delete-student/${id}`;
            document.body.appendChild(deleteForm);
            deleteForm.submit();
        }
    });

</script>

<%- include('../layout/footer') %>
