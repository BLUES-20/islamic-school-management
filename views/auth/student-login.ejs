<%- include('../layout/header') %>

<style>
    :root {
        --islamic-primary: #1a5f3f;
        --islamic-secondary: #2d7a5f;
        --islamic-accent: #3a8f6f;
        --glass-bg: rgba(255, 255, 255, 0.98);
        --shadow-soft: 0 8px 32px rgba(26, 95, 63, 0.1);
        --shadow-strong: 0 20px 60px rgba(26, 95, 63, 0.15);
        --gradient-primary: linear-gradient(135deg, var(--islamic-primary), var(--islamic-secondary));
        --gradient-accent: linear-gradient(135deg, var(--islamic-accent), var(--islamic-primary));
    }

    body {
        background: linear-gradient(135deg, #f8fdf9 0%, #e8f5ed 50%, #d4edde 100%);
        min-height: 100vh;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .login-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: var(--shadow-strong);
        overflow: hidden;
        max-width: 480px;
        width: 100%;
        position: relative;
    }

    .login-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--gradient-primary);
    }

    .login-header {
        background: var(--gradient-primary);
        padding: 3rem 2rem;
        text-align: center;
        color: white;
        position: relative;
        overflow: hidden;
    }

    .login-header::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        animation: pulse 4s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 0.5; }
        50% { transform: scale(1.1); opacity: 0.8; }
    }

    .login-icon {
        width: 80px;
        height: 80px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        backdrop-filter: blur(10px);
        border: 2px solid rgba(255, 255, 255, 0.3);
        position: relative;
        z-index: 2;
    }

    .login-icon i {
        font-size: 2.5rem;
        color: white;
    }

    .login-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        position: relative;
        z-index: 2;
    }

    .login-subtitle {
        opacity: 0.9;
        font-size: 1rem;
        position: relative;
        z-index: 2;
    }

    .login-body {
        padding: 3rem 2.5rem;
    }

    .form-floating {
        margin-bottom: 1.5rem;
    }

    .form-floating > label {
        padding: 1rem;
        font-weight: 500;
        color: #6c757d;
        font-size: 0.9rem;
    }

    .form-control {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f8f9fa;
    }

    .form-control:focus {
        border-color: var(--islamic-primary);
        box-shadow: 0 0 0 4px rgba(26, 95, 63, 0.1);
        background: white;
        transform: translateY(-1px);
    }

    .input-group-text {
        background: var(--gradient-primary);
        color: white;
        border: 2px solid var(--islamic-primary);
        border-radius: 12px 0 0 12px;
        padding: 0 1rem;
    }

    .form-check {
        margin-bottom: 2rem;
    }

    .form-check-input:checked {
        background-color: var(--islamic-primary);
        border-color: var(--islamic-primary);
    }

    .form-check-label {
        color: #6c757d;
        font-weight: 500;
        cursor: pointer;
    }

    .btn-login {
        background: var(--gradient-primary);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-weight: 600;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
        color: white;
        width: 100%;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .btn-login::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s;
    }

    .btn-login:hover::before {
        left: 100%;
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-strong);
        color: white;
    }

    .login-footer {
        background: #f8f9fa;
        padding: 2rem 2.5rem;
        border-top: 1px solid #e9ecef;
        text-align: center;
    }

    .login-links {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .login-links a {
        color: var(--islamic-primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        padding: 0.5rem 1rem;
        border-radius: 8px;
    }

    .login-links a:hover {
        background: rgba(26, 95, 63, 0.1);
        color: var(--islamic-secondary);
        transform: translateY(-1px);
    }

    .register-link {
        color: #6c757d !important;
        font-weight: 500;
    }

    .register-link a {
        color: var(--islamic-primary) !important;
        font-weight: 700;
    }

    .staff-link {
        color: #6c757d !important;
        font-size: 0.85rem;
    }

    .staff-link:hover {
        background: rgba(108, 117, 125, 0.1) !important;
    }

    @media (max-width: 576px) {
        .login-card {
            margin: 1rem;
            border-radius: 16px;
        }

        .login-header {
            padding: 2rem 1.5rem;
        }

        .login-body {
            padding: 2rem 1.5rem;
        }

        .login-footer {
            padding: 1.5rem;
        }

        .login-links {
            flex-direction: column;
            gap: 0.5rem;
        }
    }

    /* Animation for form entrance */
    .login-card {
        animation: slideUp 0.6s ease-out;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="login-container">
    <div class="login-card">
        <!-- Header -->
        <div class="login-header">
            <div class="login-icon">
                <i class="fas fa-user-graduate"></i>
            </div>
            <h1 class="login-title">Student Portal</h1>
            <p class="login-subtitle">Access your academic journey</p>
        </div>

        <!-- Body -->
        <div class="login-body">
            <form action="/auth/student-login" method="POST" class="needs-validation" novalidate>
                <div class="form-floating mb-3">
                    <input type="text" name="admission_number" class="form-control" id="admission_number" placeholder="STU2025001" required>
                    <label for="admission_number">
                        <i class="fas fa-id-card me-2"></i>Admission Number
                    </label>
                </div>

                <div class="form-floating mb-4">
                    <input type="password" name="password" class="form-control" id="password" placeholder="••••••••" required>
                    <label for="password">
                        <i class="fas fa-lock me-2"></i>Portal Password
                    </label>
                </div>

                <div class="login-links">
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" id="remember_stu">
                        <label class="form-check-label" for="remember_stu">
                            Remember me
                        </label>
                    </div>
                    <a href="/auth/forgot-password" class="text-decoration-none">
                        <i class="fas fa-key me-1"></i>Forgot Password?
                    </a>
                </div>

                <button type="submit" class="btn btn-login">
                    <i class="fas fa-sign-in-alt me-2"></i>Enter Portal
                </button>
            </form>
        </div>

        <!-- Footer -->
        <div class="login-footer">
            <p class="register-link mb-3">
                New student? <a href="/auth/student-register">Enroll Now</a>
            </p>
            <a href="/auth/staff-login" class="staff-link">
                <i class="fas fa-user-tie me-1"></i>Staff Portal Access
            </a>
        </div>
    </div>
</div>

<%- include('../layout/footer') %>
